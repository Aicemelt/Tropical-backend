# ===============================
# Database (MariaDB)
# ===============================
DB_URL=jdbc:mariadb://localhost:3306/tropical_db
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ===============================
# JWT (Base64 인코딩 권장)
# ===============================
# 안전한 Base64 키 생성: openssl rand -base64 64
JWT_SECRET=your_base64_encoded_jwt_secret_key_here
JWT_ACCESS_TOKEN_EXPIRATION=900000        # 15분 (ms 단위)
JWT_REFRESH_TOKEN_EXPIRATION=1209600000   # 14일 (ms 단위)
JWT_EMAIL_VERIFY_EXPIRATION=1800000       # 30분 (ms 단위) - 이메일 인증용
JWT_PASSWORD_RESET_EXPIRATION=3600000     # 1시간 (ms 단위) - 비밀번호 재설정용
JWT_ONBOARDING_TOKEN_EXPIRATION=1800000   # 30분 (ms 단위) - 소셜 로그인 온보딩용

# ===============================
# OAuth2 Clients
# ===============================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret

NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ===============================
# Mail (SMTP 발신 서버) - 이메일 인증에 필수
# ===============================
# 선택 1) DEV: Mailpit (실제 발송 안 됨, http://localhost:8025에서 미리보기)
# — 사용하려면 아래 주석 해제 후 Gmail, Naver 값을 주석 처리
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_AUTH=false
# SMTP_STARTTLS=false
# SMTP_SSL=false
# SMTP_FROM=noreply@tropical.local
# SMTP_FROM_NAME=TropiCal

# 선택 2) Gmail (실제 이메일 인증 발송 - 권장)
# — Gmail 2단계 인증 후 '앱 비밀번호' 발급 필요
# — 사용하려면 아래 주석 해제 후 Mailpit, Naver 값을 주석 처리
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx  # Gmail 앱 비밀번호
SMTP_AUTH=true
SMTP_STARTTLS=true
SMTP_SSL=false
SMTP_FROM=your_account@gmail.com
SMTP_FROM_NAME=TropiCal

# 선택 3) Naver (실제 이메일 인증 발송)
# — 계정 설정에서 POP3/SMTP 허용 필요
# — 사용하려면 아래 주석 해제 후 Mailpit, Gmail 값을 주석 처리
# SMTP_HOST=smtp.naver.com
# SMTP_PORT=587
# SMTP_USERNAME=your_account@naver.com
# SMTP_PASSWORD=your_naver_password
# SMTP_AUTH=true
# SMTP_STARTTLS=true
# SMTP_SSL=false
# SMTP_FROM=your_account@naver.com
# SMTP_FROM_NAME=TropiCal

# ===============================
# 메일 옵션
# ===============================
MAIL_ENABLED=true                          # 이메일 발송 활성화 (false시 인증 비활성화)
MAIL_REDIRECT_TO=                          # (선택) 테스트용 이메일 리다이렉트
MAIL_BCC=                                  # (선택) BCC 사본
MAIL_REPLY_TO=                             # (선택) 회신 주소

# ===============================
# 공휴일 API 설정
# ===============================
# 공공데이터포털에서 발급받은 한국천문연구원 특일 정보 API 서비스키
# 발급 URL: https://www.data.go.kr/data/15012690/openapi.do
HOLIDAY_API_KEY=your_holiday_api_service_key_here

# ===============================
# AI API 설정
# ===============================
# AI 스몰토크 주제 추천을 위한 AI API 키 - google gemini, openai
# 발급 URL(gemini): https://aistudio.google.com/apikey
# 발급 URL(gpt): https://platform.openai.com/settings/organization/api-keys
GEMINI_API_KEY=your_gemini_api_service_key_here
GEMINI_MODEL=your_gemini_model_here
GPT_API_KEY=your_gpt_api_service_key_here
GPT_MODEL=your_gpt_model_here

# ===============================
# App Base URL (이메일 인증 링크 생성에 사용)
# ===============================
APP_BASE_URL=http://localhost:9005         # 백엔드 베이스 URL

# ===============================
# Server
# ===============================
SERVER_PORT=9005

# ===============================
# 온보딩 토큰 시스템 설명
# ===============================
#
# JWT_ONBOARDING_TOKEN_EXPIRATION:
# - 소셜 로그인(Google, Kakao, Naver) 후 약관 동의 및 추가 정보 입력을 위한 제한된 토큰
# - 이 토큰으로는 /api/auth/onboarding 엔드포인트에만 접근 가능
# - 온보딩 완료 후 정식 ACCESS/REFRESH 토큰으로 교체됨
# - 로컬 계정(이메일 회원가입)은 회원가입 시 온보딩이 완료되므로 이 토큰을 사용하지 않음

# ===============================
# 이메일 인증 시스템 설정 가이드
# ===============================
#
# 1. Gmail 앱 비밀번호 발급 방법:
#    - Google 계정 관리 → 보안
#    - 2단계 인증 설정 (필수)
#    - 앱 비밀번호 생성
#    - 생성된 16자리 비밀번호를 SMTP_PASSWORD에 입력
#
# 2. 개발 환경 테스트:
#    - Mailpit 사용 시: docker run -d -p 1025:1025 -p 8025:8025 axllent/mailpit
#    - http://localhost:8025에서 발송된 메일 확인 가능
#
# 3. 프로덕션 환경:
#    - Gmail, Naver 등 실제 SMTP 서버 사용
#    - SPF/DKIM/DMARC 설정 권장 (수신함 도달률 향상)

# ===============================
# Base64 JWT 시크릿 생성 방법
# ===============================
# 1) OpenSSL 사용 (권장):
#    openssl rand -base64 64
#
# 2) Node.js 사용:
#    node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
#
# 3) Python 사용:
#    python -c "import os, base64; print(base64.b64encode(os.urandom(64)).decode())"