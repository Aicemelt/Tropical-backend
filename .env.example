# ===============================
# Database (MariaDB)
# ===============================
DB_URL=jdbc:mariadb://localhost:3306/tropical_db
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# ===============================
# JWT
# ===============================
JWT_SECRET=your_jwt_secret_key
JWT_ACCESS_TOKEN_EXPIRATION=900000        # 15분 (ms 단위)
JWT_REFRESH_TOKEN_EXPIRATION=604800000    # 7일 (ms 단위)

# ===============================
# OAuth2 Clients
# ===============================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_CLIENT_SECRET=your_kakao_client_secret

NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# ===============================
# Mail (SMTP 발신 서버)
# ===============================
# 선택 1) DEV: Mailpit (실제 발송 안 됨, http://localhost:8025에서 미리보기) — 사용하려면 아래 주석 해제 후 위 Gmail, Naver 값을 주석 처리
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_AUTH=false
# SMTP_STARTTLS=false
# SMTP_SSL=false
# SMTP_FROM=noreply@tropical.local

# 선택 2) Gmail (소규모 실제 발송) — 사용하려면 아래 주석 해제 후 위 Mailpit, Naver 값을 주석 처리
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_account@gmail.com
# SMTP_PASSWORD=your_app_password        # 2단계 인증 후 '앱 비밀번호' 필요
# SMTP_AUTH=true
# SMTP_STARTTLS=true
# SMTP_SSL=false
# SMTP_FROM=your_account@gmail.com

# 선택 3) Naver (소규모 실제 발송) — 계정 설정에서 POP3/SMTP 허용 필요 — 사용하려면 아래 주석 해제 후 위 Mailpit, Gmail 값을 주석 처리
# SMTP_HOST=smtp.naver.com
# SMTP_PORT=587
# SMTP_USERNAME=your_account@naver.com
# SMTP_PASSWORD=your_naver_password
# SMTP_AUTH=true
# SMTP_STARTTLS=true
# SMTP_SSL=false
# SMTP_FROM=your_account@naver.com

# ===============================
# 메일 옵션
# ===============================
EMAIL_HTML_ENABLED=false       # 나중에 true로 바꾸면 HTML 템플릿 메일 발송

# ===============================
# App Base URL (이메일 인증 링크 생성에 사용)
# ===============================
APP_BASE_URL=http://localhost:5005

# ===============================
# Server
# ===============================
SERVER_PORT=9005
